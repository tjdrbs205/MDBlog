<div class="card">
  <div class="card-header">
    <h2 class="mb-0">게시글 수정</h2>
  </div>
  <div class="card-body">
    <form action="/posts/<%= post._id %>/edit" method="POST">
      <!-- CSRF 토큰 -->
      <% if (typeof csrfToken !== 'undefined') { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% } %>
      <!-- 제목 -->
      <div class="mb-3">
        <label for="title" class="form-label">제목</label>
        <input type="text" class="form-control" id="title" name="title" value="<%= post.title %>">
      </div>
      
      <!-- 카테고리 -->
      <div class="mb-3">
        <label for="category" class="form-label">카테고리</label>
        <select class="form-select" id="category" name="category">
          <option value="">카테고리 선택</option>
          <% if (categories && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>" <%= post.category && post.category.toString() === cat._id.toString() ? 'selected' : '' %>>
                <%= cat.name %>
              </option>
            <% }); %>
          <% } %>
        </select>
      </div>
      
      <!-- 태그 -->
      <div class="mb-3">
        <label for="tags" class="form-label">태그</label>
        <div class="input-group">
          <input type="text" class="form-control" id="tags" name="tags" 
                 value="<%= post.tags && post.tags.map ? post.tags.map(t => t.name || '').join(', ') : '' %>"
                 placeholder="쉼표로 구분하여 입력 (예: Node.js, MongoDB, Express)">
          <% if (tags && tags.length > 0) { %>
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">태그 목록</button>
            <ul class="dropdown-menu dropdown-menu-end">
              <% tags.forEach(tag => { %>
                <li><a class="dropdown-item tag-item" href="#" data-tag="<%= tag.name %>"><%= tag.name %></a></li>
              <% }); %>
            </ul>
          <% } %>
        </div>
        <div class="form-text">쉼표로 구분하여 여러 태그를 입력할 수 있습니다.</div>
      </div>
      
      <!-- 공개 여부 -->
      <div class="mb-3">
        <label class="form-label">공개 여부</label>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="isPublic" id="isPublicYes" value="true" 
                 <%= post.isPublic === undefined || post.isPublic ? 'checked' : '' %>>
          <label class="form-check-label" for="isPublicYes">공개</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="isPublic" id="isPublicNo" value="false"
                 <%= post.isPublic === false ? 'checked' : '' %>>
          <label class="form-check-label" for="isPublicNo">비공개</label>
        </div>
      </div>
      
      <!-- 상태 -->
      <div class="mb-3">
        <label for="status" class="form-label">상태</label>
        <select class="form-select" id="status" name="status">
          <option value="published" <%= post.status === 'published' || !post.status ? 'selected' : '' %>>게시</option>
          <option value="draft" <%= post.status === 'draft' ? 'selected' : '' %>>임시저장</option>
        </select>
      </div>
      
      <!-- 내용 -->
      <div class="mb-3">
        <label for="editor" class="form-label">내용</label>
        <div id="editor-container" style="min-height: 500px;">
          <textarea class="form-control" id="editor" name="content" rows="20" style="min-height: 500px;"><%= post.content %></textarea>
        </div>
      </div>
      
      <!-- 버튼 -->
      <div class="d-flex justify-content-between">
        <a href="/posts/<%= post._id %>" class="btn btn-secondary">취소</a>
        <button type="submit" class="btn btn-primary">수정 완료</button>
      </div>
    </form>
  </div>
</div>

<!-- CKEditor 스크립트 -->
<script src="/node_modules/ckeditor5-build-classic/build/ckeditor.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    // 전역 변수로 선언
    window.editor = null;

    // 폼과 버튼 요소 가져오기
    const form = document.querySelector("form");
    const submitButton = form.querySelector('button[type="submit"]');

    ClassicEditor.create(document.querySelector("#editor"), {
      toolbar: ["heading", "bold", "italic", "link", "bulletedList", "numberedList", "blockQuote", "insertTable", "imageUpload", "undo", "redo"],
      image: {
        toolbar: ["imageTextAlternative", "imageStyle:full", "imageStyle:side"],
        upload: {
          types: ["jpeg", "png", "gif", "jpg"],
        },
        // 캡션 기능 비활성화
        caption: {
          defaultImageCaption: "",
          captionPlaceholder: "",
        },
      },
      simpleUpload: {
        // 이미지 업로드 URL 설정
        uploadUrl: "/api/upload/image",
        withCredentials: true,
        headers: {
          "X-CSRF-TOKEN": "<%= csrfToken %>",
        },
        // 응답 처리 함수 추가
        onUploadResponse: (response) => {
          console.log('이미지 업로드 응답:', response);
          return {
            default: response.url
          };
        }
      }
    })
      .then((editorInstance) => {
        // 전역 변수에 저장
        window.editor = editorInstance;
        console.log("CKEditor 초기화 완료");

        // 에디터 높이 조정
        const editorElement = document.querySelector(".ck-editor__editable");
        if (editorElement) {
          editorElement.style.minHeight = "500px";
          editorElement.style.maxHeight = "800px";
        }

        // 이미지 업로드 과정 모니터링
        if (editorInstance.plugins.has('FileRepository')) {
          const fileRepository = editorInstance.plugins.get('FileRepository');
          fileRepository.createUploadAdapter = (loader) => {
            console.log('업로드 어댑터 생성');
            return {
              upload: () => {
                return new Promise((resolve, reject) => {
                  const file = loader.file;
                  file.then(file => {
                    console.log('업로드할 파일:', file.name);
                    
                    const formData = new FormData();
                    formData.append('upload', file);
                    
                    // CSRF 토큰 추가
                    const csrfToken = '<%= csrfToken %>';
                    
                    fetch('/api/upload/image', {
                      method: 'POST',
                      body: formData,
                      headers: {
                        'X-CSRF-TOKEN': csrfToken
                      },
                      credentials: 'same-origin'
                    })
                    .then(response => response.json())
                    .then(result => {
                      if (result.uploaded) {
                        console.log('업로드 성공:', result.url);
                        resolve({ default: result.url });
                      } else {
                        console.error('업로드 실패:', result.error);
                        reject(result.error.message);
                      }
                    })
                    .catch(error => {
                      console.error('업로드 오류:', error);
                      reject('이미지 업로드 중 오류가 발생했습니다.');
                    });
                  });
                });
              },
              abort: () => {
                console.log('업로드 취소');
              }
            };
          };
        }

        // 캡션 요소 숨김 처리를 위한 CSS 추가
        const style = document.createElement("style");
        style.innerHTML = ".ck-editor__nested-editable { display: none !important; }";
        document.head.appendChild(style);
      })
      .catch((error) => {
        console.error("CKEditor 초기화 오류:", error);
      });

    // 수동 폼 제출 처리
    submitButton.addEventListener('click', function(event) {
      event.preventDefault();
      
      // 필수 필드 검사
      const titleField = form.querySelector('#title');
      if (!titleField.value.trim()) {
        alert('제목을 입력해주세요.');
        titleField.focus();
        return false;
      }
      
      // CKEditor 내용을 hidden input에 설정
      if (window.editor) {
        const editorData = window.editor.getData();
        
        if (!editorData.trim()) {
          alert('내용을 입력해주세요.');
          window.editor.focus();
          return false;
        }
        
        // 숨겨진 input 필드 생성 또는 업데이트
        let hiddenInput = document.getElementById('editor-content');
        if (!hiddenInput) {
          hiddenInput = document.createElement('input');
          hiddenInput.type = 'hidden';
          hiddenInput.name = 'content';
          hiddenInput.id = 'editor-content';
          form.appendChild(hiddenInput);
        }
        
        hiddenInput.value = editorData;
        console.log('폼 제출 준비 완료');
      }
      
      // 폼 제출 실행
      console.log('폼 제출 중...');
      form.submit();
      return true;
    });
  });
</script>

<style>
  /* CKEditor 크기 조정 스타일 */
  .ck-editor__editable {
    min-height: 500px !important;
    max-height: 800px !important;
  }
  
  .ck.ck-editor {
    width: 100% !important;
  }
  
  .ck-editor__main {
    max-height: 800px;
    overflow-y: auto;
  }
  
  /* 이미지 캡션 숨기기 */
  .ck-editor__nested-editable {
    display: none !important;
  }
  
  /* 이미지 캡션 요소 주변 여백 제거 */
  figure.image {
    margin-bottom: 0.5em !important;
  }
  
  /* 에디터 내부 이미지 크기 제한 */
  .ck-content .image img {
    max-width: 100% !important;
    height: auto !important;
  }
  
  .ck-content figure.image {
    max-width: 100% !important;
    margin: 1em auto;
  }
</style>
